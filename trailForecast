    dlBikeShuffleAvg = bikePrediction.groupby('Time', as_index = False)['prediction'].mean()
    dlBikeShuffleMedian = bikePrediction.groupby('Time', as_index = False)['prediction'].mean()
    YBikeShuffleAvg = bikePrediction.groupby('Time', as_index = False)['target'].mean()
    print(f'MAE of Average: {round(sum(abs(dlBikeShuffleAvg.prediction - YBikeShuffleAvg.target))/sum(YBikeShuffleAvg.target)*100,1)}')
    print(f'MAE of Median: {round(sum(abs(dlBikeShuffleMedian.prediction - YBikeShuffleAvg.target))/sum(YBikeShuffleAvg.target)*100,1)}')

    for i in np.arange(math.floor(len(features) / (14 * 24)) + 1):
        plt.figure()
        plt.plot(dlBikeShuffleAvg.Time[(i * 24 * 14):((i + 1) * 14 * 24)], YBikeShuffleAvg.target[(i * 24 * 14):((i + 1) * 14 * 24)])
        plt.plot(dlBikeShuffleAvg.Time[(i * 24 * 14):((i + 1) * 14 * 24)], dlBikeShuffleAvg.prediction[(i * 24 * 14):((i + 1) * 14 * 24)], '--b',
                alpha=0.5)
        plt.xticks(rotation=45)
        plt.legend(['Actual', 'Projection'])
        plt.pause(1)
    plt.show()