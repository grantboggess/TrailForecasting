def createModel(numLayers, units1, units2, units3, regularization): 
    model = keras.Sequential()
    if numLayers >= 1: 
        model.add(Dense(units1, activation = 'relu', input_dim = 18, kernel_regularizer = keras.regularizers.l2(regularization)))
    if numLayers >= 2: 
        model.add(Dense(units2, activation = 'relu', kernel_regularizer = keras.regularizers.l2(regularization)))
    if numLayers >= 3: 
        model.add(Dense(units3, activation = 'relu', kernel_regularizer = keras.regularizers.l2(regularization)))
    model.add(Dense(1))
    model.compile(optimizer = 'adam', loss = summedAvgError, metrics = ['mean_absolute_error', summedAvgError])
    return model


def model_builder(hp): 
    model = keras.Sequential()
    numLayers = hp.Int("layers", min_value = 1, max_value = 3, step = 1)
    units1 = hp.Int("unit1", min_value = 10, max_value = 100, step = 10)
    units2 = hp.Int("unit2", min_value = 10, max_value = 100, step = 10)
    units3 = hp.Int("unit3", min_value = 10, max_value = 100, step = 10)
    regularization = hp.Float("regularization", min_value = 0, max_value = 0.01, step = 0.001)
    model = createModel(numLayers, units1, units2, units3, regularization)
    return model

def findClosestWindSpeed(wxData, i):
    wxDataReduc = wxData[(wxData.DATE <= (wxData.DATE.loc[i] + pd.Timedelta(hours=1))) & (
                wxData.DATE >= (wxData.DATE.loc[i] - pd.Timedelta(hours=1)))].reset_index(drop=True)
    wxDataReduc['timeDif'] = abs(wxDataReduc.DATE - wxData.DATE.loc[i])
    wxDataReduc = wxDataReduc.sort_values(by=['timeDif'], ignore_index=True)
    for windSpeed in wxDataReduc.WND:
        windSpeed = float(windSpeed.split(',')[3])
        if windSpeed < 999:
            return windSpeed
            break
def findClosestWindDirection(wxData, i):
    wxDataReduc = wxData[(wxData.DATE <= (wxData.DATE.loc[i] + pd.Timedelta(hours=2))) & (
                wxData.DATE >= (wxData.DATE.loc[i] - pd.Timedelta(hours=2)))].reset_index(drop=True)
    wxDataReduc['timeDif'] = abs(wxDataReduc.DATE - wxData.DATE.loc[i])
    wxDataReduc = wxDataReduc.sort_values(by=['timeDif'], ignore_index=True)
    for windDir in wxDataReduc.WND: 
        windDir = float(windDir.split(',')[0])
        if windDir < 999:
            return windDir
    return 0
def findClosestCeiling(wxData, i):
    wxDataReduc = wxData[(wxData.DATE <= (wxData.DATE.loc[i] + pd.Timedelta(hours=2))) & (
                wxData.DATE >= (wxData.DATE.loc[i] - pd.Timedelta(hours=2)))].reset_index(drop=True)
    wxDataReduc['timeDif'] = abs(wxDataReduc.DATE - wxData.DATE.loc[i])
    wxDataReduc = wxDataReduc.sort_values(by=['timeDif'], ignore_index=True)
    for ceiling in wxDataReduc.CIG: 
        ceiling = float(ceiling.split(',')[0]) / 1000
        if ceiling < 99:
            return ceiling
    return 0
def findClosestCloudCover(wxData, i):
    wxDataReduc = wxData[(wxData.DATE <= (wxData.DATE.loc[i] + pd.Timedelta(hours=12))) & (
                wxData.DATE >= (wxData.DATE.loc[i] - pd.Timedelta(hours=12)))].reset_index(drop=True)
    wxDataReduc['timeDif'] = abs(wxDataReduc.DATE - wxData.DATE.loc[i])
    wxDataReduc = wxDataReduc.sort_values(by=['timeDif'], ignore_index=True)
    for cloudCover in wxDataReduc.GF1:
        if isinstance(cloudCover, str): 
            try: 
                cloudCover = float(cloudCover.split(',')[0])
                if cloudCover < 99:
                    return cloudCover
            except: 
                print(cloudCover)
            
    return 0


